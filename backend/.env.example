# ClassPulse360 Environment Variables

# The connection string to your remote Supabase PostgreSQL database.
# Note: Use transaction pooler (port 6543) or session pooler (port 5432) with sslmode=require.
# Example: postgresql://postgres.[YOUR-PROJECT-ID]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL="postgresql://postgres:password@host:port/database?sslmode=require"

# Environment: development, staging, production, testing
ENVIRONMENT="development"
